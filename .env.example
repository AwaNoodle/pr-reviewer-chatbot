# GitHub Configuration
VITE_GITHUB_PAT=          # GitHub Personal Access Token
VITE_GITHUB_INSTANCE=github.com  # "github.com" or URL for GHES (e.g., github.mycompany.com)

# LLM Configuration
VITE_LLM_API_KEY=         # LLM API Key
VITE_LLM_BACKEND=openai   # "openai" or "litellm"
VITE_LLM_ENDPOINT=https://api.openai.com/v1  # API endpoint URL
VITE_LLM_MODEL=gpt-4o     # Model name

# Proxy Configuration
# The Vite dev server proxies both /api/llm → VITE_LLM_ENDPOINT and
# /api/github → GitHub API to avoid CORS issues in the browser.
# Set to "false" only when a proper reverse proxy is already in place
# (e.g. in production) or when both APIs already send CORS headers.
VITE_USE_PROXY=true

# App Configuration
VITE_DEMO_MODE=true        # Start in demo mode with dummy data
